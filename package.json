{
    "name": "titanium-builds",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "npm run build:css && next build",
        "build:css": "tailwindcss -m -i styles/site.css -o public/styles/site.css",
        "dev": "concurrently \"npm run dev:css\" \"next dev\"",
        "dev:css": "tailwindcss -w -i styles/site.css -o public/styles/site.css",
        "start": "next start",
        "lint": "oxlint"
    },
    "dependencies": {
        "globby": "^16.2.0",
        "gray-matter": "^4.0.3",
        "markdown-it": "^14.1.1",
        "next": "^16.2.6",
        "pretty-bytes": "^7.1.0",
        "querystring": "^0.2.1",
        "react": "^19.2.6",
        "react-copy-to-clipboard": "^5.1.1",
        "react-dom": "^19.2.6",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.4",
        "@tailwindcss/postcss": "^4.2.4",
        "@tailwindcss/typography": "^0.5.19",
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^25.6.2",
        "@types/react": "^19.2.14",
        "@types/uuid": "^11.0.0",
        "autoprefixer": "^10.5.0",
        "concurrently": "^9.2.1",
        "oxlint": "^1.63.0",
        "postcss": "^8.5.14",
        "tailwindcss": "^4.2.4",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=24"
    }
}
